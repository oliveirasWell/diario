# Root envs (source of truth). Run: pnpm env:sync to propagate.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MongoDB (choose either full URI or components)
# Preferred: full connection string with database name
MONGODB_URI=

# Optional components (used to build MONGODB_URI if empty)
# Example for Atlas SRV host: cluster0.xxxxxx.mongodb.net
MONGO_USER=
MONGO_PASSWORD=
MONGODB_HOST=
MONGODB_DB=diario
MONGODB_OPTIONS=retryWrites=true&w=majority
